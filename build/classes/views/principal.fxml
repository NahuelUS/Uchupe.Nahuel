<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PrincipalController">
   <children>
      <ListView fx:id="listViewProductos" layoutX="27.0" layoutY="42.0" prefHeight="200.0" prefWidth="452.0" />
      <Button fx:id="btnAgregar" layoutX="491.0" layoutY="52.0" mnemonicParsing="false" onAction="#agregarProducto" prefHeight="26.0" prefWidth="94.0" text="Agregar" />
      <Button fx:id="btnModificar" layoutX="491.0" layoutY="115.0" mnemonicParsing="false" onAction="#modificarProducto" prefHeight="26.0" prefWidth="94.0" text="Modificar" />
      <Button fx:id="btnEliminar" layoutX="491.0" layoutY="173.0" mnemonicParsing="false" onAction="#eliminarProducto" prefHeight="26.0" prefWidth="94.0" text="Eliminar" />
      <Button fx:id="btnExportarCaros" layoutX="463.0" layoutY="268.0" mnemonicParsing="false" onAction="#exportarCaros" prefHeight="26.0" prefWidth="122.0" text="Exportar +$500.000" />
      <Button fx:id="btnVerTotal" layoutX="463.0" layoutY="359.0" mnemonicParsing="false" onAction="#verTotalInventario" prefHeight="26.0" prefWidth="114.0" text="Ver Total" />
      <Button fx:id="btnVerReporte" layoutX="491.0" layoutY="305.0" mnemonicParsing="false" onAction="#verReporteCaros" prefHeight="26.0" prefWidth="86.0" text="Ver Reporte" />
   </children>
</AnchorPane>
